                  </td>
                </tr>
              </tbody>
            </table>
            <table align="center" width="100%" border="0" cellPadding="0" cellSpacing="0" role="presentation">
              <tbody>
                <tr>
                  <td>
                    <h2>What can we help you with?</h2>
                    <table align="center" width="100%" border="0" cellPadding="0" cellSpacing="0" role="presentation" style="padding-left:0.75rem;padding-right:0.75rem">
                      <tbody>
                        <tr>
                          <td>
                            <table align="center" width="100%" border="0" cellPadding="0" cellSpacing="0" role="presentation" style="height:3rem">
                              <tbody style="width:100%">
                                <tr style="width:100%">
                                  <td data-id="__react-email-column" style="width:50%">Funder requirements related to RDM</td>
                                  <td data-id="__react-email-column" style="width:50%">Research data storage solutions</td>
                                </tr>
                              </tbody>
                            </table>
                            <table align="center" width="100%" border="0" cellPadding="0" cellSpacing="0" role="presentation" style="height:3rem">
                              <tbody style="width:100%">
                                <tr style="width:100%">
                                  <td data-id="__react-email-column" style="width:50%">Publishing data &amp; software</td>
                                  <td data-id="__react-email-column" style="width:50%">Ethics applications &amp; Informed consent forms</td>
                                </tr>
                              </tbody>
                            </table>
                            <table align="center" width="100%" border="0" cellPadding="0" cellSpacing="0" role="presentation" style="height:3rem">
                              <tbody style="width:100%">
                                <tr style="width:100%">
                                  <td data-id="__react-email-column" style="width:50%">Implementation of FAIR data</td>
                                  <td data-id="__react-email-column">Privacy questions</td>
                                </tr>
                              </tbody>
                            </table>
                            <table align="center" width="100%" border="0" cellPadding="0" cellSpacing="0" role="presentation" style="height:3rem">
                              <tbody style="width:100%">
                                <tr style="width:100%">
                                  <td data-id="__react-email-column" style="width:50%">Data Management Plans</td>
                                  <td data-id="__react-email-column" style="width:50%">Legal agreements and Impact assessments</td>
                                </tr>
                              </tbody>
                            </table>
                          </td>
